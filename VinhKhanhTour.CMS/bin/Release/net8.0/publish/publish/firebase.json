{
    "hosting": {
        "public": "publish/wwwroot",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "/tour",
                "destination": "/tour.html"
            },
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    }
}