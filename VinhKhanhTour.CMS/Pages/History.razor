@page "/history"
@inject CmsApiService Api

<MudText Typo="Typo.h4" Class="mb-4">📋 Lịch sử ứng dụng</MudText>

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" sm="3">
            <MudSelect @bind-Value="_filterAction" Label="Hành động"
                       Clearable="true" Variant="Variant.Outlined">
                <MudSelectItem Value="@("")">Tất cả</MudSelectItem>
                <MudSelectItem Value="@("play_poi")">🔊 Nghe POI</MudSelectItem>
                <MudSelectItem Value="@("scan_qr")">📷 Quét QR</MudSelectItem>
                <MudSelectItem Value="@("route_start")">🗺️ Chỉ đường</MudSelectItem>
                <MudSelectItem Value="@("language_change")">🌐 Đổi ngôn ngữ</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect @bind-Value="_filterLang" Label="Ngôn ngữ"
                       Clearable="true" Variant="Variant.Outlined">
                <MudSelectItem Value="@("")">Tất cả</MudSelectItem>
                <MudSelectItem Value="@("vi")">🇻🇳 Tiếng Việt</MudSelectItem>
                <MudSelectItem Value="@("en")">🇬🇧 English</MudSelectItem>
                <MudSelectItem Value="@("zh")">🇨🇳 中文</MudSelectItem>
                <MudSelectItem Value="@("ja")">🇯🇵 日本語</MudSelectItem>
                <MudSelectItem Value="@("ko")">🇰🇷 한국어</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudDatePicker Label="Lọc theo ngày" @bind-Date="_filterDate" 
                           Editable="true" Clearable="true" Variant="Variant.Outlined" 
                           DateFormat="dd/MM/yyyy" Placeholder="Chọn ngày..." />
        </MudItem>
        <MudItem xs="12" sm="3" Class="d-flex align-center">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       OnClick="LoadData" StartIcon="@Icons.Material.Filled.Refresh">
                Tải lại
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="FilteredHistory" Hover="true" Striped="true"
              HorizontalScrollbar="true" Breakpoint="Breakpoint.None">
        <HeaderContent>
            <MudTh Style="min-width:160px">Thời gian</MudTh>
            <MudTh Style="min-width:140px">Hành động</MudTh>
            <MudTh Style="min-width:180px">POI</MudTh>
            <MudTh Style="min-width:100px">Ngôn ngữ</MudTh>
            <MudTh Style="min-width:140px">Thiết bị</MudTh>
            <MudTh Style="min-width:100px">Thời lượng</MudTh>
            <MudTh Style="min-width:120px">Vị trí</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                @context.Timestamp.ToLocalTime().ToString("dd/MM HH:mm")
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small"
                         Color="GetActionColor(context.Action)">
                    @GetActionLabel(context.Action)
                </MudChip>
            </MudTd>
            <MudTd>@context.PoiName</MudTd>
            <MudTd>@GetLangFlag(context.Language)</MudTd>
            <MudTd>@context.Device</MudTd>
            <MudTd>
                @if (context.Duration > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                        @(context.Duration) s
                    </MudChip>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Default">--</MudText>
                }
            </MudTd>
            <MudTd>
                @if (context.Lat != 0 && context.Lng != 0)
                {
                    <MudLink href="@($"https://www.google.com/maps?q={context.Lat},{context.Lng}")" Target="_blank">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Error" />
                        @($"{context.Lat:F3},{context.Lng:F3}")
                    </MudLink>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Default">--</MudText>
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">Chưa có dữ liệu lịch sử</MudText>
        </NoRecordsContent>
    </MudTable>

    <MudText Typo="Typo.caption" Class="mt-2">
        Tổng: @FilteredHistory.Count() bản ghi
    </MudText>
}

@code {
    List<AppHistory> _history = new();
    bool _loading = true;
    string _filterAction = "";
    string _filterLang = "";
    DateTime? _filterDate;
 
    IEnumerable<AppHistory> FilteredHistory => _history
        .Where(h => string.IsNullOrEmpty(_filterAction) || h.Action == _filterAction)
        .Where(h => string.IsNullOrEmpty(_filterLang) || h.Language == _filterLang)
        .Where(h => !_filterDate.HasValue || h.Timestamp.ToLocalTime().Date == _filterDate.Value.Date);

    protected override async Task OnInitializedAsync() => await LoadData();

    async Task LoadData()
    {
        _loading = true;
        _history = (await Api.GetHistoryAsync() ?? new())
            .Where(h => h.Action != "open_app")
            .ToList();
        _loading = false;
    }

    string GetActionLabel(string action) => action switch
    {
        "open_app" => "📱 Mở app",
        "play_poi" => "🔊 Nghe POI",
        "listen_poi" => "🔊 Nghe POI",
        "scan_qr" => "📷 Quét QR",
        "route_start" => "🗺️ Chỉ đường",
        "language_change" => "🌐 Đổi ngôn ngữ",
        _ => action
    };

    Color GetActionColor(string action) => action switch
    {
        "open_app" => Color.Info,
        "play_poi" => Color.Success,
        "listen_poi" => Color.Success,
        "scan_qr" => Color.Warning,
        "route_start" => Color.Primary,
        "language_change" => Color.Secondary,
        _ => Color.Default
    };

    string GetLangFlag(string lang) => lang switch
    {
        "vi" => "🇻🇳 VI",
        "en" => "🇬🇧 EN",
        "zh" => "🇨🇳 ZH",
        "ja" => "🇯🇵 JA",
        "ko" => "🇰🇷 KO",
        _ => lang
    };
}