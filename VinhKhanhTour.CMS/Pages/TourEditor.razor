@page "/tours/new"
@page "/tours/edit/{Id}"
@using VinhKhanhTour.Shared.Models
@using System.Net.Http.Json
@inject CmsApiService Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>@(IsEdit ? "Sửa Tour" : "Thêm Tour Mới") — VinhKhanhTour</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-8">
    <div class="d-flex align-items-center gap-4">
        <MudText Typo="Typo.h3" Style="font-weight: 900; color: #fb923c; display: flex; align-items: center; gap: 12px;">
            <MudIcon Icon="@(IsEdit ? Icons.Material.Filled.EditNote : Icons.Material.Filled.Add)" Size="Size.Large" />
            @(IsEdit ? "Sửa Tour" : "Thêm Tour Mới")
        </MudText>
    </div>

    <div class="d-flex gap-3">
        <MudButton Variant="Variant.Outlined" 
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick='() => Nav.NavigateTo("/tours")'
                   Style="color: #6a7282; border-color: #334155; border-radius: 12px; font-weight: 600; padding: 10px 20px;">
            Quay lại
        </MudButton>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveTour"
                   Disabled="_saving"
                   Style="background: #fb923c; border-radius: 12px; padding: 10px 32px; font-weight: 800; box-shadow: 0 8px 25px rgba(251, 146, 60, 0.3);">
            @(_saving ? "ĐANG LƯU..." : "LƯU TOUR")
        </MudButton>
    </div>
</div>

<div class="vk-editor-container">
    @* --- Left Panel: Information --- *@
    <div class="vk-editor-panel info-panel">
        <MudText Typo="Typo.subtitle2" Class="mb-4 opacity-50">THÔNG TIN CƠ BẢN</MudText>
        
        <MudTextField @bind-Value="_tour.Name" Label="Tên Tour" Variant="Variant.Outlined" FullWidth Class="mb-4" />
        
        <MudTextField @bind-Value="_tour.Desc" Label="Mô tả chi tiết" Variant="Variant.Outlined" 
                      Lines="4" FullWidth Class="mb-4" />

        <div class="mb-4">
            <MudText Typo="Typo.caption" Class="mb-1 d-block opacity-70">HÌNH ẢNH ĐẠI DIỆN</MudText>
            <div class="vk-upload-area">
                @if (!string.IsNullOrEmpty(_tour.ImageUrl))
                {
                    <img src="@(_tour.ImageUrl.StartsWith("/") ? "https://vinhkhanh-api.onrender.com" + _tour.ImageUrl : _tour.ImageUrl)" class="vk-upload-preview" />
                }
                <div class="vk-upload-overlay">
                    <MudFileUpload T="IBrowserFile" FilesChanged="UploadImage">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.CloudUpload">
                                Tải ảnh lên
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                </div>
            </div>
            <MudTextField @bind-Value="_tour.ImageUrl" Label="Hoặc dán URL ảnh tại đây" 
                          Variant="Variant.Text" Margin="Margin.Dense" Class="mt-2" />
        </div>

        <MudDivider Class="my-6 opacity-10" />

        <MudSelect T="string" @bind-Value="_tour.QrType" Label="Loại Mã QR" Variant="Variant.Outlined" Class="mb-4">
            <MudSelectItem Value="@("play")">🔊 Play Audio (Quét là nghe)</MudSelectItem>
            <MudSelectItem Value="@("navigate")">🗺️ Navigate (Chỉ đường)</MudSelectItem>
        </MudSelect>

        <MudSwitch @bind-Value="_tour.IsActive" Label="Kích hoạt Tour" Color="Color.Success" />
    </div>

    @* --- Right Panel: Map & Route --- *@
    <div class="vk-editor-panel map-panel">
        <div id="tour-map" class="vk-map-container mb-4"></div>

        <div class="d-flex gap-4 mb-4">
            <div class="vk-coord-card start">
                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Success" Size="Size.Small" />
                <div>
                    <MudText Typo="Typo.caption">Điểm bắt đầu (A)</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 700; font-family: monospace">
                        @(_pointA != null ? $"{_pointA[0]:F6}, {_pointA[1]:F6}" : "---")
                    </MudText>
                </div>
            </div>
            <div class="vk-coord-card end">
                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Error" Size="Size.Small" />
                <div>
                    <MudText Typo="Typo.caption">Điểm kết thúc (B)</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 700; font-family: monospace">
                        @(_pointB != null ? $"{_pointB[0]:F6}, {_pointB[1]:F6}" : "---")
                    </MudText>
                </div>
            </div>
        </div>

        @if (_distance > 0)
        {
            <div class="vk-distance-bar mb-6">
                <MudIcon Icon="@Icons.Material.Filled.SquareFoot" Size="Size.Small" />
                <MudText Typo="Typo.body2" Style="font-weight: 700;">
                    Quãng đường: @_distance.ToString("N2") km
                </MudText>
            </div>
        }

        <div class="mt-4">
            <MudText Typo="Typo.subtitle2" Class="mb-3 opacity-50" Style="display: flex; align-items: center; gap: 8px;">
                <MudIcon Icon="@Icons.Material.Filled.PushPin" Size="Size.Small" />
                ĐIỂM DỪNG TRÊN LỘ TRÌNH (@_poisOnRoute.Count điểm)
            </MudText>
            <div class="vk-poi-list">
                @if (!_poisOnRoute.Any())
                {
                    <div class="pa-4 text-center opacity-30" style="border: 1px dashed rgba(255,255,255,0.1); border-radius: 12px;">
                        Chưa có điểm dừng nào được chọn
                    </div>
                }
                @foreach (var poi in _poisOnRoute)
                {
                    <div class="vk-poi-item">
                        <div class="vk-poi-index">@(_poisOnRoute.IndexOf(poi) + 1)</div>
                        <div class="vk-poi-info">
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@poi.Name</MudText>
                            <MudText Typo="Typo.caption" Class="opacity-50">@poi.Latitude:F6, @poi.Longitude:F6</MudText>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                       Size="Size.Small" 
                                       OnClick="() => RemovePoi(poi.Id)"
                                       Style="color: #ef4444; background: rgba(239, 68, 68, 0.1);" />
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .vk-editor-container {
        display: grid;
        grid-template-columns: 400px 1fr;
        gap: 24px;
        height: calc(100vh - 200px);
    }

    .vk-editor-panel {
        background: rgba(30, 41, 59, 0.45);
        backdrop-filter: blur(28px);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        padding: 32px;
        overflow-y: auto;
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    }

    .vk-map-container {
        height: 480px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.1);
        z-index: 10;
        overflow: hidden;
    }

    .vk-coord-card {
        flex: 1;
        padding: 16px;
        background: rgba(0,0,0,0.2);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .vk-coord-card.start { border-left: 4px solid #10b981; }
    .vk-coord-card.end { border-left: 4px solid #ef4444; }

    .vk-distance-bar {
        background: rgba(251, 146, 60, 0.1);
        color: #fb923c;
        padding: 12px 20px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 12px;
        border: 1px solid rgba(251, 146, 60, 0.2);
    }

    .vk-upload-area {
        height: 240px;
        border-radius: 20px;
        background: rgba(0,0,0,0.3);
        border: 2px dashed rgba(255,255,255,0.12);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
    }

    .vk-upload-area:hover { border-color: #fb923c; background: rgba(0,0,0,0.4); }

    .vk-upload-preview {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .vk-upload-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .vk-upload-area:hover .vk-upload-overlay { opacity: 1; }

    .vk-poi-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .vk-poi-item {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px 16px;
        background: rgba(255,255,255,0.04);
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,0.06);
        transition: transform 0.2s;
    }

    .vk-poi-item:hover { transform: scale(1.02); background: rgba(255,255,255,0.07); }

    .vk-poi-index {
        width: 32px;
        height: 32px;
        background: #fb923c;
        color: white;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 14px;
        box-shadow: 0 4px 10px rgba(251, 146, 60, 0.4);
    }

    .vk-poi-info { flex-grow: 1; }

    /* Override MudBlazor colors for dark/orange theme */
    .mud-input.mud-input-outlined { background: rgba(0,0,0,0.25); border-radius: 12px; }
    .mud-input-label { color: rgba(255,255,255,0.4) !important; }

    /* Override MudBlazor colors for dark/orange theme */
    .mud-input.mud-input-outlined { background: rgba(0,0,0,0.2); }
</style>

@code {
    [Parameter] public string? Id { get; set; }
    private bool IsEdit => !string.IsNullOrEmpty(Id);

    private TourModel _tour = new();
    private List<PoiModel> _allPois = new();
    private List<PoiModel> _poisOnRoute = new();
    private bool _loading = true;
    private bool _saving = false;
    private bool _mapInitialized = false;
    private double _distance = 0;
    private DotNetObjectReference<TourEditor>? _objRef;

    protected override async Task OnInitializedAsync()
    {
        _allPois = await Api.GetPoisAsync() ?? new();
        
        if (IsEdit)
        {
            var tours = await Api.GetToursAsync();
            _tour = tours?.FirstOrDefault(t => t.Id == Id) ?? new();
        }
        
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading && !_mapInitialized)
        {
            _mapInitialized = true;
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initTourEditorMap", _objRef);
        }
    }

    private double[]? _pointA;
    private double[]? _pointB;

    [JSInvokable]
    public async Task OnRouteSelected(double lat1, double lng1, double lat2, double lng2)
    {
        _pointA = new[] { lat1, lng1 };
        _pointB = new[] { lat2, lng2 };

        // Tính quãng đường bằng Haversine
        _distance = GetDistance(lat1, lng1, lat2, lng2);

        var coords = new[]
        {
            new[] { lat1, lng1 },
            new[] { lat2, lng2 }
        };

        // Vẽ đường thẳng A → B trên bản đồ
        await JS.InvokeVoidAsync("drawTourRoute", new object[] { coords });

        // Tự động gợi ý POI dọc lộ trình
        FindPoisAround(lat1, lng1, lat2, lng2);
        StateHasChanged();
    }

    private void RemovePoi(string id)
    {
        _poisOnRoute.RemoveAll(p => p.Id == id);
    }

    private void FindPoisAround(double lat1, double lng1, double lat2, double lng2)
    {
        _poisOnRoute.Clear();
        foreach (var poi in _allPois)
        {
            // Kiểm tra POI có gần điểm A hoặc điểm B hoặc trung điểm không (bán kính ~500m)
            var d1 = GetDistance(lat1, lng1, poi.Latitude, poi.Longitude);
            var d2 = GetDistance(lat2, lng2, poi.Latitude, poi.Longitude);
            var midLat = (lat1 + lat2) / 2;
            var midLng = (lng1 + lng2) / 2;
            var d3 = GetDistance(midLat, midLng, poi.Latitude, poi.Longitude);

            if (d1 < 0.5 || d2 < 0.5 || d3 < 0.5)
            {
                if (!_poisOnRoute.Any(p => p.Id == poi.Id))
                    _poisOnRoute.Add(poi);
            }
        }
    }

    private double GetDistance(double lat1, double lon1, double lat2, double lon2)
    {
        var R = 6371; // km
        var dLat = (lat2 - lat1) * Math.PI / 180;
        var dLon = (lon2 - lon1) * Math.PI / 180;
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180) *
                Math.Sin(dLon / 2) * Math.Sin(dLon / 2);
        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
        return R * c;
    }

    private async Task UploadImage(IBrowserFile file)
    {
        try 
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024); // 5MB
            var url = await Api.UploadImageAsync(stream, file.Name);
            if (!string.IsNullOrEmpty(url))
            {
                _tour.ImageUrl = url;
                Snackbar.Add("Đã tải ảnh lên thành công!", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi upload: " + ex.Message, Severity.Error);
        }
    }

    private async Task SaveTour()
    {
        if (string.IsNullOrEmpty(_tour.Name))
        {
            Snackbar.Add("Vui lòng nhập tên tour!", Severity.Warning);
            return;
        }

        _saving = true;
        
        // Cập nhật danh sách POI ID vào tour
        _tour.PoiIds = _poisOnRoute.Select(p => p.Id).ToList();

        var resp = await Api.SaveTourAsync(_tour);
        if (resp.IsSuccessStatusCode)
        {
            Snackbar.Add("✅ Đã lưu tour thành công!", Severity.Success);
            Nav.NavigateTo("/tours");
        }
        else
        {
            Snackbar.Add("❌ Lỗi khi lưu tour!", Severity.Error);
        }
        _saving = false;
    }

    public void Dispose() => _objRef?.Dispose();

    // Helper classes for OSRM
    public class OsrmResponse {
        [System.Text.Json.Serialization.JsonPropertyName("routes")]
        public List<OsrmRoute> Routes { get; set; } = new();
    }
    public class OsrmRoute {
        [System.Text.Json.Serialization.JsonPropertyName("distance")]
        public double Distance { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("geometry")]
        public string Geometry { get; set; } = "";
    }
}
