@page "/poi/{PoiId}"
@using VinhKhanhTour.Shared.Models
@inject CmsApiService Api
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>@(_poi?.Name ?? "Loading...") — Vinh Khánh Tour</PageTitle>

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
    }
    .hero-gradient {
        background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
        min-height: 100vh;
        color: white;
    }
    .status-badge {
        padding: 4px 12px;
        border-radius: 99px;
        font-size: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .pay-button {
        background: linear-gradient(90deg, #FFD700 0%, #FFA500 100%) !important;
        color: #000 !important;
        font-weight: 800 !important;
        border-radius: 16px !important;
        box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3) !important;
    }
    .player-card {
        background: rgba(0, 255, 127, 0.1);
        border: 1px solid rgba(0, 255, 127, 0.2);
    }
</style>

<div class="hero-gradient px-4 py-8">
    <div class="max-w-md mx-auto">
        @if (_loading)
        {
            <div class="flex flex-col items-center justify-center py-20">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body1" Class="mt-4" Style="color:rgba(255,255,255,0.6)">Đang chuẩn bị thuyết minh...</MudText>
            </div>
        }
        else if (_poi == null)
        {
            <div class="glass-card pa-8 text-center">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Error" Size="Size.Large" />
                <MudText Typo="Typo.h5" Class="mt-4 font-bold">Không tìm thấy địa điểm</MudText>
                <MudText Typo="Typo.body2" Class="mt-2 text-white/50">Mã QR này có vẻ không tồn tại trong hệ thống.</MudText>
            </div>
        }
        else
        {
            @* ── Header Content ── *@
            <div class="text-center mb-6">
                <div class="text-6xl mb-4">
                     @(_poi.Category?.ToLower() switch
                    {
                        "food" => "🍜",
                        "drink" => "🥤",
                        "landmark" => "🏛️",
                        _ => "📍"
                    })
                </div>
                <MudText Typo="Typo.h4" Style="font-weight:900; letter-spacing:-0.5px;">@_poi.Name</MudText>
                <div class="flex items-center justify-center gap-2 mt-2">
                    <span class="status-badge bg-white/10 text-white/70">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" /> Quận 4, TP.HCM
                    </span>
                    @if (_poi.RequirePayment && !_hasAccess)
                    {
                        <span class="status-badge bg-orange-500/20 text-orange-400">
                             <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" /> Có thu phí
                        </span>
                    }
                    else
                    {
                        <span class="status-badge bg-green-500/20 text-green-400">
                             <MudIcon Icon="@Icons.Material.Filled.LockOpen" Size="Size.Small" /> Miễn phí
                        </span>
                    }
                </div>
            </div>

            @* ── Main Action Card ── *@
            <div class="glass-card pa-6 mb-6">
                @if (_poi.RequirePayment && !_hasAccess)
                {
                    <div class="text-center py-4">
                        <div class="text-white/40 mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.Payments" Style="font-size: 64px;" />
                        </div>
                        <MudText Typo="Typo.h6" Class="font-bold mb-2">Trải nghiệm Thuyết minh cao cấp</MudText>
                        <MudText Typo="Typo.body2" Class="mb-6 text-white/60">
                            Nghe thuyết minh audio chuyên nghiệp đa ngôn ngữ chỉ với một ly trà đá. Quyền truy cập có hiệu lực trong 24h.
                        </MudText>
                        
                        <MudButton Variant="Variant.Filled" 
                                   Class="pay-button py-4" 
                                   FullWidth="true"
                                   OnClick="HandlePayment"
                                   Disabled="_processing">
                            @if (_processing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                                <span>ĐANG XỬ LÝ...</span>
                            }
                            else
                            {
                                <span>THANH TOÁN: @(_poi.Price.ToString("N0")) VNĐ</span>
                            }
                        </MudButton>
                    </div>
                }
                else
                {
                    @* ── Audio Player Unlocked ── *@
                    <div class="player-card pa-4 rounded-xl mb-4 text-center">
                        <MudText Typo="Typo.subtitle1" Class="font-bold text-green-400 mb-3 flex items-center justify-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" /> ĐÃ MỞ KHÓA AUDIO
                        </MudText>
                        
                        <div class="space-y-4">
                            @foreach (var kv in _poi.AudioUrls.Where(a => !string.IsNullOrEmpty(a.Value)))
                            {
                                <div class="bg-black/20 p-3 rounded-lg border border-white/5">
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="text-lg">@GetLangFlag(kv.Key)</span>
                                        <MudText Typo="Typo.caption" Class="font-bold text-white/80">@GetLangName(kv.Key)</MudText>
                                    </div>
                                    <audio controls class="w-full" preload="metadata">
                                        <source src="@kv.Value" type="audio/mpeg">
                                    </audio>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            @* ── Detail Content ── *@
            <div class="glass-card pa-6">
                <MudText Typo="Typo.subtitle1" Class="font-bold mb-3 flex items-center gap-2 text-white/80">
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" /> GIỚI THIỆU
                </MudText>
                
                @if (!_hasAccess && _poi.RequirePayment)
                {
                    <div class="relative">
                        <MudText Typo="Typo.body2" Class="text-white/40 leading-relaxed select-none">
                            @(viContent.Length > 150 ? viContent[..150] : viContent)
                        </MudText>
                        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/80 flex items-end justify-center pb-2">
                             <MudText Typo="Typo.caption" Class="italic text-orange-300">Nội dung đã bị ẩn, vui lòng thanh toán.</MudText>
                        </div>
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="text-white/80 leading-relaxed">
                        @viContent
                    </MudText>
                }
            </div>

            <div class="text-center mt-8 text-white/30">
                <MudText Typo="Typo.caption">© 2026 Vinh Khanh Food Tour • Powered by Antigravity</MudText>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string PoiId { get; set; } = "";

    PoiModel? _poi;
    bool _loading = true;
    bool _hasAccess = false;
    bool _processing = false;
    string _deviceId = "";
    string viContent = "";

    protected override async Task OnInitializedAsync()
    {
        // 1. Lấy deviceId từ localStorage (hoặc tạo mới)
        _deviceId = await JS.InvokeAsync<string>("localStorage.getItem", "vinhkhanh_visitor_id");
        if (string.IsNullOrEmpty(_deviceId))
        {
            _deviceId = Guid.NewGuid().ToString("N")[..12];
            await JS.InvokeVoidAsync("localStorage.setItem", "vinhkhanh_visitor_id", _deviceId);
        }

        // 2. Load POI
        var pois = await Api.GetPoisAsync();
        _poi = pois?.FirstOrDefault(p => p.Id == PoiId);

        if (_poi != null)
        {
            viContent = _poi.Content.TryGetValue("vi", out var c) ? c : "Không có dữ liệu.";
            
            // 3. Kiểm tra quyền truy cập
            _hasAccess = await Api.CheckAccessAsync(PoiId, _deviceId);
        }

        _loading = false;
    }

    async Task HandlePayment()
    {
        _processing = true;
        try 
        {
            // Giả lập thanh toán (2 giây)
            await Task.Delay(1500);

            var resp = await Api.PayAsync(PoiId, _deviceId);
            if (resp.IsSuccessStatusCode)
            {
                _hasAccess = true;
                Snackbar.Add("Thanh toán thành công! Bạn có thể nghe thuyết minh ngay bây giờ.", Severity.Success);
            }
            else 
            {
                Snackbar.Add("Có lỗi xảy ra khi xử lý thanh toán.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi kết nối API.", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    string GetLangFlag(string lang) => lang switch
    {
        "vi" => "🇻🇳",
        "en" => "🇬🇧",
        "zh" => "🇨🇳",
        "ja" => "🇯🇵",
        "ko" => "🇰🇷",
        _ => "🌐"
    };

    string GetLangName(string lang) => lang switch
    {
        "vi" => "Tiếng Việt",
        "en" => "English",
        "zh" => "中文",
        "ja" => "日本語",
        "ko" => "한국어",
        _ => lang
    };
}
