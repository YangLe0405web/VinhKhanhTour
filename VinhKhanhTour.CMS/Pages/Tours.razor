@page "/tours"
@using VinhKhanhTour.Shared.Models
@inject CmsApiService Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Quản lý Tour — VinhKhanhTour</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-6">
    <div class="d-flex align-items-center gap-3">
        <div class="vk-page-icon">
            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Large" Style="color: #fb923c;" />
        </div>
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 800; color: #fb923c; letter-spacing: -0.5px;">
                Quản lý Tour
            </MudText>
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.5);">
                Tổng cộng: <b>@(_tours.Count) tour</b>
            </MudText>
        </div>
    </div>

    <MudButton Variant="Variant.Filled" 
               StartIcon="@Icons.Material.Filled.Add"
               OnClick='() => Nav.NavigateTo("/tours/new")'
               Style="background: linear-gradient(90deg, #fb923c, #f97316); color: white; border-radius: 12px; padding: 10px 24px; font-weight: 700; box-shadow: 0 4px 15px rgba(249, 115, 22, 0.3);">
        Thêm Tour Mới
    </MudButton>
</div>

@if (_loading)
{
    <div class="d-flex justify-content-center py-10">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
    </div>
}
else if (_tours.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="rounded-xl">
        Chưa có tour nào trong hệ thống. Hãy tạo tour đầu tiên để bắt đầu trải nghiệm!
    </MudAlert>
}
else
{
    <div class="vk-tour-grid">
        @foreach (var tour in _tours)
        {
            <div class="vk-tour-card">
                <div class="vk-tour-img-wrapper">
                    @if (!string.IsNullOrEmpty(tour.ImageUrl))
                    {
                        <img src="@tour.ImageUrl" alt="@tour.Name" class="vk-tour-img" />
                    }
                    else
                    {
                        <div class="vk-tour-img-placeholder">
                            <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Large" />
                        </div>
                    }
                    <div class="vk-tour-status-badge @(tour.IsActive ? "active" : "")">
                        @(tour.IsActive ? "Đang hoạt động" : "Tạm dừng")
                    </div>
                </div>

                <div class="vk-tour-content">
                    <MudText Typo="Typo.h6" Class="vk-tour-title">@tour.Name</MudText>
                    <MudText Typo="Typo.body2" Class="vk-tour-desc">@tour.Desc</MudText>
                    
                    <div class="vk-tour-actions">
                        <MudButton Variant="Variant.Filled" 
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick='() => Nav.NavigateTo($"/tours/edit/{tour.Id}")'
                                   Class="flex-grow-1 rounded-lg"
                                   Style="background: rgba(255,255,255,0.1); color: white; backdrop-filter: blur(5px);">
                            Sửa
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" 
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   OnClick="() => DeleteTour(tour.Id)"
                                   Class="rounded-lg"
                                   Style="color: #ef4444; border-color: rgba(239, 68, 68, 0.3); background: rgba(239, 68, 68, 0.05);">
                            Xóa
                        </MudButton>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .vk-tour-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
        animation: vkFadeIn 0.5s ease;
    }

    .vk-tour-card {
        background: rgba(30, 41, 59, 0.5);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
    }

    .vk-tour-card:hover {
        transform: translateY(-8px);
        border-color: rgba(251, 146, 60, 0.4);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4), 0 0 20px rgba(251, 146, 60, 0.1);
    }

    .vk-tour-img-wrapper {
        position: relative;
        height: 180px;
        overflow: hidden;
    }

    .vk-tour-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .vk-tour-card:hover .vk-tour-img {
        transform: scale(1.08);
    }

    .vk-tour-img-placeholder {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #1e293b, #0f172a);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,0.1);
    }

    .vk-tour-status-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        padding: 4px 12px;
        border-radius: 99px;
        font-size: 11px;
        font-weight: 700;
        background: rgba(15, 23, 42, 0.8);
        color: rgba(255,255,255,0.6);
        backdrop-filter: blur(4px);
    }

    .vk-tour-status-badge.active {
        background: rgba(34, 197, 94, 0.2);
        color: #4ade80;
        border: 1px solid rgba(74, 222, 128, 0.3);
    }

    .vk-tour-content {
        padding: 20px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .vk-tour-title {
        font-weight: 700;
        color: white;
        margin-bottom: 8px;
    }

    .vk-tour-desc {
        color: rgba(255,255,255,0.5);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 20px;
        line-height: 1.6;
    }

    .vk-tour-actions {
        margin-top: auto;
        display: flex;
        gap: 12px;
    }

    @@keyframes vkFadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    List<TourModel> _tours = new();
    bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _tours = await Api.GetToursAsync() ?? new();
        _loading = false;
    }

    async Task DeleteTour(string id)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync(
            "Xác nhận xoá",
            "Bạn có chắc muốn xoá tour này không?",
            yesText: "Xoá", cancelText: "Huỷ");
        if (confirm != true) return;

        await Api.DeleteTourAsync(id);
        _tours.RemoveAll(t => t.Id == id);
        Snackbar.Add("Đã xóa tour!", Severity.Success);
    }
}
