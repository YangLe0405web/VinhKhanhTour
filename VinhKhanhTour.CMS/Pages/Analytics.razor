@page "/"
@attribute [Authorize]
@inject HttpClient Http
@inject CmsApiService Api
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">📈 Dashboard (Precision Stats)</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" 
               StartIcon="@Icons.Material.Filled.Refresh" 
               Disabled="_loading"
               OnClick="@(() => LoadAllData(true))">Làm mới</MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid>
        @if (_isAdmin)
        {
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h3" Color="Color.Success">@((_totalRevenue + _totalMerchantRevenue).ToString("N0"))</MudText>
                    <MudText Typo="Typo.subtitle1">Tổng doanh thu (VND)</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h3" Color="Color.Secondary">@(_totalMerchantRevenue.ToString("N0"))</MudText>
                    <MudText Typo="Typo.subtitle1">Doanh thu Đăng ký (VND)</MudText>
                </MudPaper>
            </MudItem>
        }
        else
        {
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h3" Color="Color.Primary">@_totalQr</MudText>
                    <MudText Typo="Typo.subtitle1">Lượt quét QR</MudText>
                </MudPaper>
            </MudItem>
        }

        @if (_isAdmin)
        {
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h3" Color="Color.Primary">@_totalQr</MudText>
                    <MudText Typo="Typo.subtitle1">Lượt quét QR</MudText>
                </MudPaper>
            </MudItem>
        }
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Info">@_totalPlay</MudText>
                <MudText Typo="Typo.subtitle1">Lượt nghe Audio</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Warning">@_avgDuration s</MudText>
                <MudText Typo="Typo.subtitle1">Thời gian nghe TB</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">🏆 Top POI được nghe nhiều nhất</MudText>
                <MudTable Items="_topPois" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>#</MudTh><MudTh>POI</MudTh><MudTh>Lượt</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@(_topPois.IndexOf(context) + 1)</MudTd>
                        <MudTd>@context.Key</MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.Value</MudChip></MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">🌐 Phân bố ngôn ngữ</MudText>
                <MudTable Items="_langStats" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Ngôn ngữ</MudTh><MudTh>Lượt</MudTh><MudTh>Tỉ lệ</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@GetLangFlag(context.Key)</MudTd>
                        <MudTd>@context.Value</MudTd>
                        <MudTd>
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudProgressLinear Value="@GetPercent(context.Value)" Color="Color.Info" Class="flex-grow-1" />
                                <MudText Typo="Typo.caption">@GetPercent(context.Value).ToString("F1")%</MudText>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        @if (_isAdmin)
        {
            <MudItem xs="12">
                <MudPaper Class="pa-6" Elevation="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudText Typo="Typo.h6">📈 Thống kê doanh thu (7 ngày gần nhất)</MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Success" 
                                   StartIcon="@Icons.Custom.FileFormats.FileExcel"
                                   OnClick="ExportToExcel">Xuất Excel (.csv)</MudButton>
                    </MudStack>
                    
                    @if (_chartSeries.Count > 0)
                    {
                        <MudChart ChartType="ChartType.Line" ChartSeries="@_chartSeries" 
                                   @bind-SelectedIndex="_chartIndex" ChartLabels="@_chartLabels" 
                                   Width="100%" Height="350px" ChartOptions="@_chartOptions" />
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">Chưa đủ dữ liệu để vẽ biểu đồ doanh thu</MudAlert>
                    }

                    <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Số tiền thanh toán quét QR theo từng ngày</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">📅 Doanh thu theo tháng</MudText>
                    <MudTable Items="_monthlyRevenue" Hover="true" Dense="true">
                        <HeaderContent>
                            <MudTh>Tháng/Năm</MudTh><MudTh>Doanh thu (VND)</MudTh><MudTh>Lượt thanh toán</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Month</MudTd>
                            <MudTd>@context.Amount.ToString("N0")</MudTd>
                            <MudTd>@context.Count</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">📍 Doanh thu theo POI</MudText>
                    <MudTable Items="_poiRevenue" Hover="true" Dense="true">
                        <HeaderContent>
                            <MudTh>POI</MudTh><MudTh>Doanh thu (VND)</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>@context.Amount.ToString("N0")</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudItem>
        }

        <AuthorizeView Roles="admin">
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">🔥 Heatmap vị trí người dùng</MudText>
                    <div id="heatmap" style="height:400px; width:100%; border-radius:8px;"></div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">🗺️ Tuyến di chuyển người dùng</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                        Tọa độ được làm tròn 3 chữ số (~111m) để bảo vệ quyền riêng tư
                    </MudText>
                    <div id="tracemap" style="height:400px; width:100%; border-radius:8px;"></div>
                </MudPaper>
            </MudItem>
        </AuthorizeView>

        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">🕒 Sự kiện gần nhất (Kiểm tra Log)</MudText>
                <MudTable Items="_unified.Take(10)" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Thời gian</MudTh>
                        <MudTh>Hành động</MudTh>
                        <MudTh>POI</MudTh>
                        <MudTh>Thiết bị</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Timestamp.ToLocalTime().ToString("HH:mm:ss dd/MM")</MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@GetActionColor(context.EventType)">@context.EventType</MudChip>
                        </MudTd>
                        <MudTd>@context.PoiName</MudTd>
                        <MudTd>@context.Device</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    class UnifiedEvent
    {
        public DateTime Timestamp { get; set; }
        public string EventType { get; set; } = "";
        public string PoiId { get; set; } = "";
        public string PoiName { get; set; } = "";
        public string Language { get; set; } = "";
        public int Duration { get; set; }
        public string Device { get; set; } = "";
        public double Lat { get; set; }
        public double Lng { get; set; }
        public double Amount { get; set; }
    }

    // Chart
    private int _chartIndex = -1;
    private ChartOptions _chartOptions = new ChartOptions();
    private List<ChartSeries> _chartSeries = new();
    private string[] _chartLabels = Array.Empty<string>();

    bool _mapsInitialized = false;
    List<LocationTrace> _traces = new();
    List<AnalyticsEvent> _events = new();
    List<AppHistory> _history = new();
    List<PoiModel> _pois = new();
    List<UnifiedEvent> _unified = new();
    bool _loading = true;
    bool _isAdmin = false;

    int _totalPlay, _totalQr, _avgDuration, _uniquePois;
    double _totalRevenue;
    double _totalMerchantRevenue;
    List<KeyValuePair<string, int>> _topPois = new();
    List<KeyValuePair<string, int>> _langStats = new();

    class RevenueGroup { public string Month { get; set; } = ""; public double Amount { get; set; } public int Count { get; set; } }
    class PoiRevenue { public string Name { get; set; } = ""; public double Amount { get; set; } }
    List<RevenueGroup> _monthlyRevenue = new();
    List<PoiRevenue> _poiRevenue = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAllData();
    }

    async Task LoadAllData(bool force = false)
    {
        _loading = true;
        StateHasChanged();
        try 
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _isAdmin = user.IsInRole("admin");
            
            var t1 = Api.GetAnalyticsAsync(force);
            var t2 = Api.GetTracesAsync(force);
            var t3 = Api.GetHistoryAsync(force);
            var t4 = Api.GetPoisAsync(force);
            
            await Task.WhenAll(t1, t2, t3, t4);
            
            var allPois = t4.Result ?? new();

            // Filter data based on Role và OwnerId
            if (_isAdmin)
            {
                _pois = allPois;
                _events = (t1.Result ?? new()).Where(e => e.EventType != "open_app").ToList();
                _traces = t2.Result ?? new();
                _history = (t3.Result ?? new()).Where(h => h.Action != "open_app").ToList();
            }
            else
            {
                var username = user.Identity?.Name ?? "";
                // Chỉ lấy POI thuộc về mình
                _pois = allPois.Where(p => p.OwnerId == username).ToList();
                var managedIds = _pois.Select(p => p.Id).ToList();

                _events = (t1.Result ?? new()).Where(e => e.EventType != "open_app" && managedIds.Contains(e.PoiId)).ToList();
                _traces = new(); // Owners don't see traces for now
                _history = (t3.Result ?? new()).Where(h => h.Action != "open_app" && managedIds.Contains(h.PoiId)).ToList();
            }
            
            BuildUnified();
            ComputeStats();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading analytics: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    void BuildUnified()
    {
        var list = new List<UnifiedEvent>();

        // 1. Nạp History trước
        foreach (var h in _history)
        {
            if (!_isAdmin && h.Action == "pay_audio") continue;

            list.Add(new UnifiedEvent
            {
                Timestamp = h.Timestamp,
                EventType = h.Action == "play_poi" ? "poi_play" : h.Action,
                PoiId = h.PoiId,
                PoiName = string.IsNullOrEmpty(h.PoiName) ? (_pois.FirstOrDefault(p => p.Id == h.PoiId)?.Name ?? "") : h.PoiName,
                Language = h.Language,
                Device = h.Device,
                Duration = h.Duration,
                Lat = h.Lat,
                Lng = h.Lng,
                Amount = h.Amount
            });
        }

        // 2. Nạp Analytics Event gộp vào dòng tương ứng (Cho data cũ)
        foreach (var e in _events.OrderBy(x => x.Timestamp))
        {
            var match = list.Where(u => 
                u.PoiId == e.PoiId && 
                (u.EventType == "poi_play" || u.EventType == "play_poi") && 
                u.Duration == 0 && 
                u.Timestamp >= e.Timestamp.AddMinutes(-5) && 
                u.Timestamp <= e.Timestamp.AddMinutes(5))
                .OrderBy(u => Math.Abs((u.Timestamp - e.Timestamp).TotalSeconds))
                .FirstOrDefault();

            if (match != null)
            {
                match.Duration = e.Duration;
                match.Lat = e.Lat;
                match.Lng = e.Lng;
            }
            else
            {
                list.Add(new UnifiedEvent
                {
                    Timestamp = e.Timestamp,
                    EventType = e.EventType,
                    PoiId = e.PoiId,
                    PoiName = _pois.FirstOrDefault(p => p.Id == e.PoiId)?.Name ?? e.PoiId,
                    Language = e.Language,
                    Duration = e.Duration,
                    Lat = e.Lat,
                    Lng = e.Lng,
                });
            }
        }

        _unified = list.OrderByDescending(e => e.Timestamp).ToList();
    }

    void ComputeStats()
    {
        _totalPlay = _unified.Count(e => IsPlayAction(e.EventType));
        _totalQr = _unified.Count(h => IsScanAction(h.EventType));
        
        _avgDuration = _unified.Any(e => e.Duration > 0)
            ? (int)_unified.Where(e => e.Duration > 0).Average(e => e.Duration) : 0;
            
        _uniquePois = _unified.Where(e => !string.IsNullOrEmpty(e.PoiId))
            .Select(e => e.PoiId).Distinct().Count();

        var payEvents = _unified.Where(e => e.EventType == "pay_audio").ToList();
        var regEvents = _unified.Where(e => e.EventType == "register_poi").ToList();

        _totalRevenue = payEvents.Sum(e => e.Amount);
        _totalMerchantRevenue = regEvents.Sum(e => e.Amount);

        _monthlyRevenue = payEvents.Concat(regEvents).GroupBy(e => e.Timestamp.ToLocalTime().ToString("MM/yyyy"))
            .Select(g => new RevenueGroup { Month = g.Key, Amount = g.Sum(e => e.Amount), Count = g.Count() })
            .OrderByDescending(x => x.Month).ToList();

        _poiRevenue = payEvents.GroupBy(e => string.IsNullOrEmpty(e.PoiName) ? e.PoiId : e.PoiName)
            .Select(g => new PoiRevenue { Name = g.Key, Amount = g.Sum(e => e.Amount) })
            .OrderByDescending(x => x.Amount).ToList();
        
        _topPois = _unified.Where(e => !string.IsNullOrEmpty(e.PoiId) && IsPlayAction(e.EventType))
            .GroupBy(e => string.IsNullOrEmpty(e.PoiName) ? e.PoiId : e.PoiName)
            .OrderByDescending(g => g.Count()).Take(5)
            .Select(g => new KeyValuePair<string, int>(g.Key, g.Count())).ToList();
            
        _langStats = _unified.Where(e => !string.IsNullOrEmpty(e.Language))
            .GroupBy(e => NormalizeLang(e.Language))
            .OrderByDescending(g => g.Count())
            .Select(g => new KeyValuePair<string, int>(g.Key, g.Count())).ToList();

        PrepareChartData();
    }

    bool IsPlayAction(string action) => 
        string.Equals(action, "poi_play", StringComparison.OrdinalIgnoreCase) || 
        string.Equals(action, "play_poi", StringComparison.OrdinalIgnoreCase) || 
        string.Equals(action, "listen_poi", StringComparison.OrdinalIgnoreCase);

    bool IsScanAction(string action) => 
        string.Equals(action, "scan_qr", StringComparison.OrdinalIgnoreCase);

    Color GetActionColor(string action) => action.ToLower() switch
    {
        "scan_qr" => Color.Success,
        "poi_play" or "play_poi" or "listen_poi" => Color.Primary,
        "route_start" => Color.Warning,
        "language_change" => Color.Secondary,
        _ => Color.Default
    };

    void PrepareChartData()
    {
        var localNow = DateTime.Now.Date;
        var startDate = localNow.AddDays(-6);
        var labels = new List<string>();
        var revenueData = new List<double>();
        var countData = new List<double>();

        for (int i = 6; i >= 0; i--)
        {
            var date = localNow.AddDays(-i);
            labels.Add(date.ToString("dd/MM"));

            var dayPays = _unified.Where(e => e.Timestamp.ToLocalTime().Date == date && e.EventType == "pay_audio");
            
            revenueData.Add(dayPays.Sum(e => e.Amount));
            countData.Add(dayPays.Count());
        }

        _chartLabels = labels.ToArray();
        _chartSeries = new List<ChartSeries>()
        {
            new ChartSeries() { Name = "Doanh thu (VND)", Data = revenueData.ToArray() },
            new ChartSeries() { Name = "Lượt thanh toán", Data = countData.ToArray() }
        };
        
        _chartOptions.ShowLegend = true;
    }

    async Task ExportToExcel()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Thoi gian,Hanh dong,POI,So tien (VND),Thiet bi,Ngon ngu");
        
        foreach (var e in _unified.Where(e => e.EventType == "pay_audio").OrderByDescending(x => x.Timestamp))
        {
            sb.AppendLine($"{e.Timestamp.ToLocalTime():dd/MM/yyyy HH:mm},{e.EventType},{e.PoiName},{e.Amount},{e.Device},{e.Language}");
        }

        var csv = sb.ToString();
        var fileName = $"DoanhThu_VinhKhanh_{DateTime.Now:ddMMyyyy}.csv";
        
        // Use the existing utility or add a new one
        await JS.InvokeVoidAsync("downloadFileFromBlob", fileName, csv, "text/csv;charset=utf-8;");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_loading || _mapsInitialized) return;
        _mapsInitialized = true;
        await Task.Delay(500);
        try
        {
            await JS.InvokeVoidAsync("initHeatmap",
                _traces.Select(t => new { lat = t.Lat, lng = t.Lng }).ToList());
            await JS.InvokeVoidAsync("initTraceMap",
                _traces.GroupBy(t => t.SessionId)
                    .Select(g => g.OrderBy(t => t.Timestamp)
                        .Select(t => new { lat = t.Lat, lng = t.Lng }).ToList()).ToList());
        }
        catch (Exception ex) { Console.WriteLine($"Map error: {ex.Message}"); }
    }

    double GetPercent(int val) => _unified.Count == 0 ? 0 : (double)val / _unified.Count * 100;

    string NormalizeLang(string lang) => lang.ToLowerInvariant().Trim() switch
    {
        "vi" or "vietnamese" or "vn" => "vi",
        "en" or "english" or "gb" => "en",
        "zh" or "chinese" or "cn" => "zh",
        "ja" or "japanese" or "jp" => "ja",
        "ko" or "korean" or "kr" => "ko",
        _ => lang.ToLowerInvariant().Trim()
    };

    string GetLangFlag(string lang) => lang.ToLowerInvariant() switch
    {
        "vi" or "vn" or "vietnamese" => "🇻🇳 Tiếng Việt",
        "en" or "english" or "gb" => "🇬🇧 English",
        "zh" or "chinese" or "cn" => "🇨🇳 中文",
        "ja" or "japanese" or "jp" => "🇯🇵 日本語",
        "ko" or "korean" or "kr" => "🇰🇷 한국어",
        _ => lang.ToUpperInvariant()
    };
}
