@page "/analytics"
@inject HttpClient Http
@inject CmsApiService Api
@inject IJSRuntime JS

<MudText Typo="Typo.h4" Class="mb-4">📊 Analytics</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Primary">@_total</MudText>
                <MudText Typo="Typo.subtitle1">Tổng lượt nghe</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Success">@_totalQr</MudText>
                <MudText Typo="Typo.subtitle1">Lượt quét QR</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Warning">@_avgDuration s</MudText>
                <MudText Typo="Typo.subtitle1">Thời gian nghe TB</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Secondary">@_uniquePois</MudText>
                <MudText Typo="Typo.subtitle1">POI được nghe</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">🏆 Top POI được nghe nhiều nhất</MudText>
                <MudTable Items="_topPois" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>#</MudTh><MudTh>POI</MudTh><MudTh>Lượt</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@(_topPois.IndexOf(context) + 1)</MudTd>
                        <MudTd>@context.Key</MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.Value</MudChip></MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">🌐 Phân bố ngôn ngữ</MudText>
                <MudTable Items="_langStats" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Ngôn ngữ</MudTh><MudTh>Lượt</MudTh><MudTh>Tỉ lệ</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@GetLangFlag(context.Key)</MudTd>
                        <MudTd>@context.Value</MudTd>
                        <MudTd>
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudProgressLinear Value="@GetPercent(context.Value)" Color="Color.Info" Class="flex-grow-1" />
                                <MudText Typo="Typo.caption">@GetPercent(context.Value).ToString("F1")%</MudText>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Class="pa-6" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">📈 Thống kê tương tác (7 ngày gần nhất)</MudText>
                
                @if (_chartSeries.Count > 0)
                {
                    <MudChart ChartType="ChartType.Line" ChartSeries="@_chartSeries" 
                              @bind-SelectedIndex="_chartIndex" ChartLabels="@_chartLabels" 
                              Width="100%" Height="350px" ChartOptions="@_chartOptions" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info">Chưa đủ dữ liệu để vẽ biểu đồ</MudAlert>
                }

                <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Biểu đồ tổng tích lũy trong 7 ngày</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">🔥 Heatmap vị trí người dùng</MudText>
                <div id="heatmap" style="height:400px; width:100%; border-radius:8px;"></div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">🗺️ Tuyến di chuyển người dùng</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                    Tọa độ được làm tròn 3 chữ số (~111m) để bảo vệ quyền riêng tư
                </MudText>
                <div id="tracemap" style="height:400px; width:100%; border-radius:8px;"></div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    class UnifiedEvent
    {
        public DateTime Timestamp { get; set; }
        public string EventType { get; set; } = "";
        public string PoiId { get; set; } = "";
        public string PoiName { get; set; } = "";
        public string Language { get; set; } = "";
        public int Duration { get; set; }
        public string Device { get; set; } = "";
        public double Lat { get; set; }
        public double Lng { get; set; }
    }

    // Chart
    private int _chartIndex = -1;
    private ChartOptions _chartOptions = new ChartOptions();
    private List<ChartSeries<double>> _chartSeries = new();
    private string[] _chartLabels = Array.Empty<string>();

    bool _mapsInitialized = false;
    List<LocationTrace> _traces = new();
    List<AnalyticsEvent> _events = new();
    List<AppHistory> _history = new();
    List<PoiModel> _pois = new();
    List<UnifiedEvent> _unified = new();
    bool _loading = true;

    int _total, _totalQr, _avgDuration, _uniquePois;
    List<KeyValuePair<string, int>> _topPois = new();
    List<KeyValuePair<string, int>> _langStats = new();

    protected override async Task OnInitializedAsync()
    {
        var t1 = Api.GetAnalyticsAsync();
        var t2 = Api.GetTracesAsync();
        var t3 = Api.GetHistoryAsync();
        var t4 = Api.GetPoisAsync();
        
        await Task.WhenAll(t1, t2, t3, t4);
        
        _events = t1.Result ?? new();
        _traces = t2.Result ?? new();
        _history = t3.Result ?? new();
        _pois = t4.Result ?? new();
        
        BuildUnified();
        ComputeStats();
        _loading = false;
    }

    void BuildUnified()
    {
        var list = new List<UnifiedEvent>();

        // 1. Nạp History trước
        foreach (var h in _history)
        {
            list.Add(new UnifiedEvent
            {
                Timestamp = h.Timestamp,
                EventType = h.Action == "play_poi" ? "poi_play" : h.Action,
                PoiId = h.PoiId,
                PoiName = string.IsNullOrEmpty(h.PoiName) ? (_pois.FirstOrDefault(p => p.Id == h.PoiId)?.Name ?? "") : h.PoiName,
                Language = h.Language,
                Device = h.Device,
                Duration = h.Duration,
                Lat = h.Lat,
                Lng = h.Lng
            });
        }

        // 2. Nạp Analytics Event gộp vào dòng tương ứng (Cho data cũ)
        foreach (var e in _events.OrderBy(x => x.Timestamp))
        {
            var match = list.Where(u => 
                u.PoiId == e.PoiId && 
                u.EventType == "poi_play" && 
                u.Duration == 0 && 
                u.Timestamp <= e.Timestamp.AddMinutes(15))
                .OrderByDescending(u => u.Timestamp)
                .FirstOrDefault();

            if (match != null)
            {
                match.Duration = e.Duration;
                match.Lat = e.Lat;
                match.Lng = e.Lng;
            }
            else
            {
                list.Add(new UnifiedEvent
                {
                    Timestamp = e.Timestamp,
                    EventType = e.EventType,
                    PoiId = e.PoiId,
                    PoiName = _pois.FirstOrDefault(p => p.Id == e.PoiId)?.Name ?? e.PoiId,
                    Language = e.Language,
                    Duration = e.Duration,
                    Lat = e.Lat,
                    Lng = e.Lng,
                });
            }
        }

        _unified = list.OrderByDescending(e => e.Timestamp).ToList();
    }

    void ComputeStats()
    {
        _total = _unified.Count(e => e.EventType == "poi_play" || e.EventType == "play_poi" || e.EventType == "listen_poi");
        _totalQr = _unified.Count(h => h.EventType == "scan_qr");
        _avgDuration = _unified.Any(e => e.Duration > 0)
            ? (int)_unified.Where(e => e.Duration > 0).Average(e => e.Duration) : 0;
        _uniquePois = _unified.Where(e => !string.IsNullOrEmpty(e.PoiId))
            .Select(e => e.PoiId).Distinct().Count();
        
        _topPois = _unified.Where(e => !string.IsNullOrEmpty(e.PoiId) && (e.EventType == "poi_play" || e.EventType == "play_poi" || e.EventType == "listen_poi"))
            .GroupBy(e => string.IsNullOrEmpty(e.PoiName) ? e.PoiId : e.PoiName)
            .OrderByDescending(g => g.Count()).Take(5)
            .Select(g => new KeyValuePair<string, int>(g.Key, g.Count())).ToList();
            
        _langStats = _unified.Where(e => !string.IsNullOrEmpty(e.Language))
            .GroupBy(e => e.Language)
            .OrderByDescending(g => g.Count())
            .Select(g => new KeyValuePair<string, int>(g.Key, g.Count())).ToList();

        // Chuẩn bị dữ liệu biểu đồ
        PrepareChartData();
    }

    void PrepareChartData()
    {
        var localNow = DateTime.Now.Date;
        var startDate = localNow.AddDays(-6);
        var labels = new List<string>();
        var scanData = new List<double>();
        var playData = new List<double>();

        // Start with absolute total before the 7-day window
        double cumulativeScan = _unified.Count(e => e.Timestamp.ToLocalTime().Date < startDate && e.EventType == "scan_qr");
        double cumulativePlay = _unified.Count(e => e.Timestamp.ToLocalTime().Date < startDate && (e.EventType == "poi_play" || e.EventType == "play_poi" || e.EventType == "listen_poi"));

        // Calculate cumulative sums for each of the last 7 days
        for (int i = 6; i >= 0; i--)
        {
            var date = localNow.AddDays(-i);
            labels.Add(date.ToString("dd/MM"));

            var dayEvents = _unified.Where(e => e.Timestamp.ToLocalTime().Date == date);
            
            cumulativeScan += dayEvents.Count(e => e.EventType == "scan_qr");
            cumulativePlay += dayEvents.Count(e => e.EventType == "poi_play" || e.EventType == "play_poi" || e.EventType == "listen_poi");
            
            scanData.Add(cumulativeScan);
            playData.Add(cumulativePlay);
        }

        _chartLabels = labels.ToArray();
        _chartSeries = new List<ChartSeries<double>>()
        {
            new ChartSeries<double>() { Name = "Quét QR", Data = scanData.ToArray() },
            new ChartSeries<double>() { Name = "Nghe Audio", Data = playData.ToArray() }
        };
        
        _chartOptions.ShowLegend = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_loading || _mapsInitialized) return;
        _mapsInitialized = true;
        await Task.Delay(500);
        try
        {
            await JS.InvokeVoidAsync("initHeatmap",
                _traces.Select(t => new { lat = t.Lat, lng = t.Lng }).ToList());
            await JS.InvokeVoidAsync("initTraceMap",
                _traces.GroupBy(t => t.SessionId)
                    .Select(g => g.OrderBy(t => t.Timestamp)
                        .Select(t => new { lat = t.Lat, lng = t.Lng }).ToList()).ToList());
        }
        catch (Exception ex) { Console.WriteLine($"Map error: {ex.Message}"); }
    }

    double GetPercent(int val) => _unified.Count == 0 ? 0 : (double)val / _unified.Count * 100;

    string GetLangFlag(string lang) => lang switch
    {
        "vi" or "vietnamese" => "🇻🇳 VI",
        "en" or "english" => "🇬🇧 EN",
        "zh" or "chinese" => "🇨🇳 ZH",
        "ja" or "japanese" => "🇯🇵 JA",
        "ko" or "korean" => "🇰🇷 KO",
        _ => lang
    };
}
