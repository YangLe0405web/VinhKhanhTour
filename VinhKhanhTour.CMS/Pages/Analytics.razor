@page "/analytics"
@inject HttpClient Http
@inject CmsApiService Api
@inject IJSRuntime JS

<MudText Typo="Typo.h4" Class="mb-4">📊 Analytics</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid>
        <!-- Thống kê tổng quan -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Primary">@_total</MudText>
                <MudText Typo="Typo.subtitle1">Tổng lượt nghe</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Success">@_totalQr</MudText>
                <MudText Typo="Typo.subtitle1">Lượt quét QR</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Warning">@_avgDuration s</MudText>
                <MudText Typo="Typo.subtitle1">Thời gian nghe TB</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Secondary">@_uniquePois</MudText>
                <MudText Typo="Typo.subtitle1">POI được nghe</MudText>
            </MudPaper>
        </MudItem>

        <!-- Top POI -->
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">🏆 Top POI được nghe nhiều nhất</MudText>
                <MudTable Items="_topPois" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>#</MudTh>
                        <MudTh>POI</MudTh>
                        <MudTh>Lượt nghe</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@(_topPois.IndexOf(context) + 1)</MudTd>
                        <MudTd>@context.Key</MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                                @context.Value
                            </MudChip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <!-- Ngôn ngữ -->
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">🌐 Phân bố ngôn ngữ</MudText>
                <MudTable Items="_langStats" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Ngôn ngữ</MudTh>
                        <MudTh>Lượt nghe</MudTh>
                        <MudTh>Tỉ lệ</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@GetLangFlag(context.Key)</MudTd>
                        <MudTd>@context.Value</MudTd>
                        <MudTd>
                            <MudProgressLinear Value="@GetPercent(context.Value)"
                                               Color="Color.Primary" Rounded="true" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <!-- Bảng chi tiết -->
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">📋 Chi tiết sự kiện</MudText>
                <MudTable Items="_events" Hover="true" Striped="true"
                          Dense="true" HorizontalScrollbar="true"
                          Breakpoint="Breakpoint.None">
                    <HeaderContent>
                        <MudTh Style="min-width:140px">Thời gian</MudTh>
                        <MudTh Style="min-width:120px">Loại</MudTh>
                        <MudTh Style="min-width:180px">POI</MudTh>
                        <MudTh Style="min-width:80px">Ngôn ngữ</MudTh>
                        <MudTh Style="min-width:80px">Thời lượng</MudTh>
                        <MudTh Style="min-width:120px">Vị trí</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Timestamp.ToLocalTime().ToString("dd/MM HH:mm")</MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                @context.EventType
                            </MudChip>
                        </MudTd>
                        <MudTd>@context.PoiId</MudTd>
                        <MudTd>@GetLangFlag(context.Language)</MudTd>
                        <MudTd>@context.Duration s</MudTd>
                        <MudTd>@context.Lat.ToString("F3"), @context.Lng.ToString("F3")</MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4">Chưa có dữ liệu analytics</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
        </MudItem>
        <!-- Heatmap -->
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">
                    🔥 Heatmap vị trí người dùng
                </MudText>
                <div id="heatmap" style="height:400px; width:100%; border-radius:8px;"></div>
            </MudPaper>
        </MudItem>

        <!-- Tuyến di chuyển -->
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">
                    🗺️ Tuyến di chuyển người dùng
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                    Tọa độ được làm tròn 3 chữ số (~111m) để bảo vệ quyền riêng tư
                </MudText>
                <div id="tracemap" style="height:400px; width:100%; border-radius:8px;"></div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    bool _mapsInitialized = false;
    List<LocationTrace> _traces = new();
    List<AnalyticsEvent> _events = new();
    bool _loading = true;

    int _total;
    int _totalQr;
    int _avgDuration;
    int _uniquePois;

    List<KeyValuePair<string, int>> _topPois = new();
    List<KeyValuePair<string, int>> _langStats = new();

    protected override async Task OnInitializedAsync()
    {
        _events = await Api.GetAnalyticsAsync() ?? new();
        _traces = await Api.GetTracesAsync() ?? new();
        ComputeStats();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_loading) return;
        if (_mapsInitialized) return;
        _mapsInitialized = true;

        await Task.Delay(500);

        try
        {
            await JS.InvokeVoidAsync("initHeatmap",
                _traces.Select(t => new { lat = t.Lat, lng = t.Lng }).ToList());

            await JS.InvokeVoidAsync("initTraceMap",
                _traces
                    .GroupBy(t => t.SessionId)
                    .Select(g => g.OrderBy(t => t.Timestamp)
                        .Select(t => new { lat = t.Lat, lng = t.Lng })
                        .ToList())
                    .ToList());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Map init error: {ex.Message}");
        }
    }

    void ComputeStats()
    {
        _total = _events.Count(e => e.EventType == "poi_play");
        _totalQr = _events.Count(e => e.EventType == "qr_scan");
        _avgDuration = _events.Any(e => e.Duration > 0)
            ? (int)_events.Where(e => e.Duration > 0).Average(e => e.Duration)
            : 0;

        _uniquePois = _events
            .Where(e => !string.IsNullOrEmpty(e.PoiId))
            .Select(e => e.PoiId)
            .Distinct().Count();

        _topPois = _events
            .Where(e => !string.IsNullOrEmpty(e.PoiId))
            .GroupBy(e => e.PoiId)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g => new KeyValuePair<string, int>(g.Key, g.Count()))
            .ToList();

        _langStats = _events
            .GroupBy(e => e.Language)
            .OrderByDescending(g => g.Count())
            .Select(g => new KeyValuePair<string, int>(g.Key, g.Count()))
            .ToList();
    }

    double GetPercent(int val)
        => _events.Count == 0 ? 0 : (double)val / _events.Count * 100;

    string GetLangFlag(string lang) => lang switch
    {
        "vi" => "🇻🇳 VI",
        "en" => "🇬🇧 EN",
        "zh" => "🇨🇳 ZH",
        "ja" => "🇯🇵 JA",
        "ko" => "🇰🇷 KO",
        _ => lang
    };
}