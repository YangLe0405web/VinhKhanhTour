@page "/pois"
@attribute [Authorize]
@using VinhKhanhTour.Shared.Models
@using QRCoder
@inject CmsApiService Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class="mb-6">
    <MudText Typo="Typo.h5" Style="font-weight: 700; color: #ffffff; display: flex; align-items: center; gap: 8px;">
        <span style="font-size: 24px;">📍</span> Quản lý POI
    </MudText>
    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.58);">
        Danh sách điểm tham quan · Vinh Khánh Tour
    </MudText>
</div>

@if (_loading)
{
    <div class="d-flex flex-column align-items-center justify-center mt-12 py-12">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Class="mt-4" Style="color: rgba(255,255,255,0.5);">Đang kết nối tới API...</MudText>
    </div>
}
else if (_error)
{
    <div class="d-flex flex-column align-items-center justify-center mt-12 py-12" style="background: rgba(244, 67, 54, 0.05); border: 1px dashed rgba(244, 67, 54, 0.3); border-radius: 16px;">
        <MudIcon Icon="@Icons.Material.Filled.WifiOff" Color="Color.Error" Style="font-size: 48px;" />
        <MudText Typo="Typo.h6" Class="mt-4" Style="color: #f44336; font-weight: 700;">Lỗi kết nối tới API Backend</MudText>
        <MudText Typo="Typo.body2" Class="mb-2 px-6 text-center" Style="color: rgba(255,255,255,0.8); max-width: 500px;">
            @_errorDetail
        </MudText>
        <MudText Typo="Typo.caption" Class="mb-6 px-6 text-center" Style="color: rgba(255,255,255,0.4); max-width: 400px;">
            Vui lòng thử lại sau 30-60 giây nếu server Render đang khởi động.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Refresh" OnClick="@(() => LoadData(true))" Style="border-radius: 99px; text-transform: none; font-weight: 600;"> Thử lại ngay </MudButton>
    </div>
}
else
{
    @* ── Stats Cards ── *@
    <MudGrid Class="mb-6" Spacing="3">
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 d-flex flex-column justify-center" Style="height: 100%;">
                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.45); font-weight: 600; letter-spacing: 1px; text-transform: uppercase;">TỔNG POI</MudText>
                <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700; margin-top: 4px;">@_pois.Count</MudText>
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.58); font-size: 11px; margin-top: 4px;">↑ 3 POI mới tháng này</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 d-flex flex-column justify-center" Style="height: 100%;">
                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.45); font-weight: 600; letter-spacing: 1px; text-transform: uppercase;">ĐANG HOẠT ĐỘNG</MudText>
                <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700; margin-top: 4px;">@_pois.Count(p => p.IsActive)</MudText>
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.58); font-size: 11px; margin-top: 4px;">
                    @(Math.Round((_pois.Count(p => p.IsActive) * 100.0) / (_pois.Count == 0 ? 1 : _pois.Count)))% tổng số POI
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 d-flex flex-column justify-center" Style="height: 100%;">
                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.45); font-weight: 600; letter-spacing: 1px; text-transform: uppercase;">LƯỢT PHÁT AUDIO</MudText>
                <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700; margin-top: 4px;">1.2k</MudText>
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.58); font-size: 11px; margin-top: 4px;">7 ngày qua</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ── Filters ── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
        <MudButton OnClick='() => SetFilter("Tất cả")' Variant='@(_currentFilter == "Tất cả" ? Variant.Outlined : Variant.Text)' Color='@(_currentFilter == "Tất cả" ? Color.Primary : Color.Default)' Size="Size.Small" Style='@(_currentFilter == "Tất cả" ? "border-radius: 99px; text-transform: none; font-weight: 600; padding: 4px 16px;" : "border-radius: 99px; color: rgba(255,255,255,0.6); text-transform: none; padding: 4px 16px;")'>Tất cả</MudButton>
        <MudButton OnClick='() => SetFilter("Ẩm thực")' Variant='@(_currentFilter == "Ẩm thực" ? Variant.Outlined : Variant.Text)' Color='@(_currentFilter == "Ẩm thực" ? Color.Primary : Color.Default)' Size="Size.Small" Style='@(_currentFilter == "Ẩm thực" ? "border-radius: 99px; text-transform: none; font-weight: 600; padding: 4px 16px;" : "border-radius: 99px; color: rgba(255,255,255,0.6); text-transform: none; padding: 4px 16px;")'>Ẩm thực 🍜</MudButton>
        <MudButton OnClick='() => SetFilter("Đồ uống")' Variant='@(_currentFilter == "Đồ uống" ? Variant.Outlined : Variant.Text)' Color='@(_currentFilter == "Đồ uống" ? Color.Primary : Color.Default)' Size="Size.Small" Style='@(_currentFilter == "Đồ uống" ? "border-radius: 99px; text-transform: none; font-weight: 600; padding: 4px 16px;" : "border-radius: 99px; color: rgba(255,255,255,0.6); text-transform: none; padding: 4px 16px;")'>Đồ uống 🧋</MudButton>
        <MudButton OnClick='() => SetFilter("Địa danh")' Variant='@(_currentFilter == "Địa danh" ? Variant.Outlined : Variant.Text)' Color='@(_currentFilter == "Địa danh" ? Color.Primary : Color.Default)' Size="Size.Small" Style='@(_currentFilter == "Địa danh" ? "border-radius: 99px; text-transform: none; font-weight: 600; padding: 4px 16px;" : "border-radius: 99px; color: rgba(255,255,255,0.6); text-transform: none; padding: 4px 16px;")'>Địa danh 🏛️</MudButton>
    </MudStack>

    @* ── Table ── *@
    <MudTable Items="_pois" Hover="true" Striped="true" Elevation="3"
              HorizontalScrollbar="true" Breakpoint="Breakpoint.None"
              Class="vk-poi-table" Filter="new Func<PoiModel,bool>(FilterPoi)">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Danh sách POI</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddDialog" Size="Size.Small" Style="border-radius: 99px; font-weight: 600; text-transform: none;">
                + Thêm POI
            </MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh Style="min-width:200px">Tên POI</MudTh>
            <MudTh Style="min-width:160px">Danh mục</MudTh>
            <MudTh>Tọa độ</MudTh>
            <MudTh Style="min-width:140px">Ngôn ngữ</MudTh>
            <MudTh Style="min-width:120px">Trạng thái</MudTh>
            <MudTh Style="min-width:120px">Giá (VNĐ)</MudTh>
            <MudTh Style="min-width:150px">Thao tác</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Tên POI" Style="font-weight:500;">@context.Name</MudTd>
            <MudTd DataLabel="Danh mục">
                @if (context.Category?.ToLower().Contains("food") == true || context.Category?.ToLower().Contains("ẩm thực") == true)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Fastfood" Style="border-radius: 99px;">Ẩm thực</MudChip>
                }
                else if (context.Category?.ToLower().Contains("drink") == true || context.Category?.ToLower().Contains("đồ uống") == true)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.LocalCafe" Style="border-radius: 99px;">Đồ uống</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.AccountBalance" Style="border-radius: 99px;">Địa danh</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Tọa độ">
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.6);">
                    @context.Latitude.ToString("F4"), @context.Longitude.ToString("F4")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Ngôn ngữ" Style="letter-spacing: 2px;">@GetFlagsRaw(context)</MudTd>
            <MudTd DataLabel="Trạng thái">
                @if (context.IsActive)
                {
                    <div @onclick="() => ToggleActive(context)" style="cursor:pointer; display:inline-flex; align-items:center; gap:6px; background: rgba(52,211,153,0.15); border: 1px solid rgba(52,211,153,0.3); border-radius: 99px; padding: 2px 10px; color: #34d399; font-size: 11px; font-weight:600; transition: all 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
                        <div style="width:6px; height:6px; background:#34d399; border-radius:50%;"></div> Active
                    </div>
                }
                else
                {
                    <div @onclick="() => ToggleActive(context)" style="cursor:pointer; display:inline-flex; align-items:center; gap:6px; background: rgba(248,113,113,0.15); border: 1px solid rgba(248,113,113,0.3); border-radius: 99px; padding: 2px 10px; color: #f87171; font-size: 11px; font-weight:600; transition: all 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
                        <div style="width:6px; height:6px; background:#f87171; border-radius:50%;"></div> Inactive
                    </div>
                }
            </MudTd>
            <MudTd DataLabel="Giá (VNĐ)">
                @if (context.RequirePayment)
                {
                    <MudText Typo="Typo.body2" Color="Color.Warning" Style="font-weight:700">
                        @context.Price.ToString("N0")
                    </MudText>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">Free</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Thao tác">
                <MudIconButton Icon="@Icons.Material.Filled.QrCode"
                                Color="Color.Secondary" Size="Size.Small"
                                Title="Xem QR thuyết minh"
                                OnClick="() => ShowQr(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                Color="Color.Primary" Size="Size.Small"
                                OnClick="() => OpenEditDialog(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                Color="Color.Error" Size="Size.Small"
                                OnClick="() => DeletePoi(context.Id)" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@* ── QR Dialog cho POI ───────────────────────────────────────────── *@
<MudDialog @bind-Visible="_showQrDialog" Options="_qrDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            📷 QR Thuyết Minh — @_qrPoi?.Name
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_qrPoi != null)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="3">

                <MudPaper Elevation="3" Class="pa-3"
                          Style="background:white;border-radius:12px">
                    <img src="@_qrImageBase64"
                         style="width:240px;height:240px;display:block" />
                </MudPaper>

                @* ── Audio Status ── *@
                @if (HasAnyAudio(_qrPoi))
                {
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mt-1" Style="width:100%">
                        <MudText Typo="Typo.body2" Style="font-weight:600">
                            🎵 POI này có file Audio thuyết minh
                        </MudText>
                        <MudText Typo="Typo.caption">
                            Khi khách quét QR, app sẽ hỏi: <b>"Nghe Audio hay dùng giọng đọc?"</b>
                        </MudText>
                    </MudAlert>

                    @* Hiện danh sách audio có sẵn theo từng ngôn ngữ *@
                    <MudPaper Outlined="true" Class="pa-3" Style="width:100%;border-radius:8px">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Audio có sẵn:</MudText>
                        @foreach (var kv in _qrPoi.AudioUrls)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1" Spacing="2">
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Style="border-radius:99px">
                                    @GetLangFlag(kv.Key) @kv.Key.ToUpper()
                                </MudChip>
                                <audio controls style="height:32px;flex:1" preload="none">
                                    <source src="@kv.Value" type="audio/mpeg" />
                                </audio>
                            </MudStack>
                        }
                    </MudPaper>
                }
                else
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-1" Style="width:100%">
                        <MudText Typo="Typo.body2" Style="font-weight:600">
                            🗣 Chưa có file Audio
                        </MudText>
                        <MudText Typo="Typo.caption">
                            Khi khách quét QR, app sẽ dùng <b>giọng đọc TTS</b> tự động.
                            Vào trang <b>Quản lý Audio</b> để upload file MP3 nếu muốn.
                        </MudText>
                    </MudAlert>
                }

                <MudPaper Outlined="true" Class="pa-2 px-3"
                          Style="width:100%;border-radius:8px">
                    <MudStack Row="true" AlignItems="AlignItems.Center"
                               Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                 Style="word-break:break-all;font-family:monospace">
                            @GetQrUrl(_qrPoi)
                        </MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                       Size="Size.Small"
                                       OnClick="() => CopyUrl(_qrPoi)" />
                    </MudStack>
                </MudPaper>

                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-1">
                    Dán QR này tại quầy <b>@_qrPoi.Name</b>.<br />
                    Khách quét → app tự đọc thuyết minh ngay,
                    <b>không cần GPS</b>, không cần mạng (TTS offline).
                </MudAlert>

            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="DownloadQr">
            Tải QR PNG
        </MudButton>
        <MudButton OnClick="CloseQrDialog">Đóng</MudButton>
    </DialogActions>
</MudDialog>

@code {
    bool _loading = true;
    bool _error = false;
    string _errorDetail = "";
    List<PoiModel> _pois = new();

    string _currentFilter = "Tất cả";

    void SetFilter(string filter)
    {
        _currentFilter = filter;
    }

    private bool FilterPoi(PoiModel poi)
    {
        if (_currentFilter == "Tất cả") return true;
        if (_currentFilter == "Ẩm thực" && (poi.Category?.ToLower().Contains("food") == true || poi.Category?.ToLower().Contains("ẩm thực") == true)) return true;
        if (_currentFilter == "Đồ uống" && (poi.Category?.ToLower().Contains("drink") == true || poi.Category?.ToLower().Contains("đồ uống") == true)) return true;
        if (_currentFilter == "Địa danh" && !poi.Category?.ToLower().Contains("food") == true && !poi.Category?.ToLower().Contains("ẩm thực") == true && !poi.Category?.ToLower().Contains("drink") == true && !poi.Category?.ToLower().Contains("đồ uống") == true) return true;
        return false;
    }

    // QR dialog
    bool _showQrDialog = false;
    PoiModel? _qrPoi = null;
    string _qrImageBase64 = "";
    DialogOptions _qrDialogOptions = new()
    {
        MaxWidth = MaxWidth.ExtraSmall,
        FullWidth = true,
        CloseOnEscapeKey = true,
        CloseButton = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData(bool force = false)
    {
        _loading = true;
        _error = false;
        StateHasChanged();
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var role = user.FindFirst(ClaimTypes.Role)?.Value;

            var allPois = await Api.GetPoisAsync() ?? new();

            if (role == "admin")
            {
                _pois = allPois;
            }
            else
            {
                // Dùng thẳng Username từ Token để lọc POI — Tuyệt đối không gọi API Profile bị lỗi
                var username = user.Identity?.Name ?? "";
                _pois = allPois.Where(p => p.OwnerId == username).ToList();
                Console.WriteLine($"🔍 [UI] Filtered {_pois.Count}/{allPois.Count} POIs for owner '{username}'");
                if (_pois.Count == 0 && allPois.Any())
                {
                    Console.WriteLine($"⚠️ [UI] No POIs matched. Sample POI OwnerId from server: '{allPois.First().OwnerId}'");
                }
            }
        }
        catch (Exception ex)
        {
            _error = true;
            _errorDetail = ex.Message;
            Snackbar.Add($"❌ Lỗi: {ex.Message}", Severity.Error);
            Console.WriteLine($"🔥 API ERROR: {ex}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    // Web link → quét QR mở trang landing, có nút nghe audio + nút mở App
    string GetQrUrl(PoiModel poi) => $"https://vinhkhanhtour-c8e3f.web.app/poi/{poi.Id}";

    void ShowQr(PoiModel poi)
    {
        _qrPoi = poi;
        var url = GetQrUrl(poi);

        using var qrGenerator = new QRCodeGenerator();
        var qrData = qrGenerator.CreateQrCode(url, QRCodeGenerator.ECCLevel.M);
        using var qrCode = new PngByteQRCode(qrData);
        var pngBytes = qrCode.GetGraphic(
            pixelsPerModule: 20,
            darkColorRgba: new byte[] { 106, 27, 154, 255 },  // tím #6A1B9A
            lightColorRgba: new byte[] { 255, 255, 255, 255 }
        );
        _qrImageBase64 = $"data:image/png;base64,{Convert.ToBase64String(pngBytes)}";
        _showQrDialog = true;
    }

    void CloseQrDialog()
    {
        _showQrDialog = false;
        _qrPoi = null;
        _qrImageBase64 = "";
    }

    async Task DownloadQr()
    {
        if (_qrPoi == null) return;
        var fileName = $"qr_poi_{_qrPoi.Id}.png";
        await JS.InvokeVoidAsync("downloadBase64File", _qrImageBase64, fileName);
    }

    async Task CopyUrl(PoiModel poi)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", GetQrUrl(poi));
        Snackbar.Add("✅ Đã copy URL!", Severity.Success);
    }

    string GetFlags(PoiModel p)
    {
        var flags = new[] { ("vi", "🇻🇳"), ("en", "🇬🇧"), ("zh", "🇨🇳"), ("ja", "🇯🇵"), ("ko", "🇰🇷") };
        return string.Join(" ", flags
            .Where(f => p.Content.ContainsKey(f.Item1))
            .Select(f => f.Item2));
    }

    string GetFlagsRaw(PoiModel p)
    {
        var flags = new[] { ("vi", "VI"), ("en", "EN"), ("zh", "ZH"), ("ja", "JA"), ("ko", "KO") };
        return string.Join(" - ", flags
            .Where(f => p.Content != null && p.Content.ContainsKey(f.Item1))
            .Select(f => f.Item2));
    }

    bool HasAnyAudio(PoiModel p) => p.AudioUrls != null && p.AudioUrls.Count > 0;

    string GetLangFlag(string lang) => lang switch
    {
        "vi" => "🇻🇳",
        "en" => "🇬🇧",
        "zh" => "🇨🇳",
        "ja" => "🇯🇵",
        "ko" => "🇰🇷",
        _ => "🌐"
    };

    async Task DeletePoi(string id)
    {
        await Api.DeletePoiAsync(id);
        _pois.RemoveAll(p => p.Id == id);
        Snackbar.Add("Đã xóa POI!", Severity.Success);
    }

    async Task ToggleActive(PoiModel poi)
    {
        poi.IsActive = !poi.IsActive;
        await Api.SavePoiAsync(poi);
        Snackbar.Add($"Đã {(poi.IsActive ? "bật" : "tắt")} hoạt động POI!", Severity.Success);
    }

    async Task OpenAddDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<PoiDialog>(
            "Thêm POI",
            new DialogParameters { ["Poi"] = new PoiModel(), ["IsEdit"] = false },
            options);

        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var poi = (PoiModel)result.Data!;
            var newId = await Api.SavePoiAsync(poi);
            
            if (!string.IsNullOrEmpty(newId))
            {
                // Sau khi lưu thành công, server đã tự gán quyền cho owner.
                // Chúng ta chỉ cần load lại danh sách.
            }

            _pois = await Api.GetPoisAsync(true) ?? new();
            await LoadData(force: true); // Load lại và phá cache
            Snackbar.Add("Đã thêm POI!", Severity.Success);
        }
    }

    async Task OpenEditDialog(PoiModel poi)
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<PoiDialog>(
            "Sửa POI",
            new DialogParameters { ["Poi"] = poi, ["IsEdit"] = true },
            options);

        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var updated = (PoiModel)result.Data!;
            await Api.SavePoiAsync(updated);
            _pois = await Api.GetPoisAsync(true) ?? new();
            await LoadData(force: true);
            Snackbar.Add("Đã cập nhật POI!", Severity.Success);
        }
    }
}
