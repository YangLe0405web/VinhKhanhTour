@inject ISnackbar Snackbar
@inject HttpClient Http

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(IsEdit ? "✏️ Sửa POI" : "➕ Thêm POI mới")
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="Poi.Name"
                               Label="Tên POI" Variant="Variant.Outlined"
                               Required="true" />
            </MudItem>
            <MudItem xs="6">
                <MudSelect @bind-Value="Poi.Category"
                           Label="Danh mục" Variant="Variant.Outlined">
                    <MudSelectItem Value="@("food")">🍜 Ẩm thực</MudSelectItem>
                    <MudSelectItem Value="@("drink")">🧋 Đồ uống</MudSelectItem>
                    <MudSelectItem Value="@("landmark")">🏛️ Địa điểm</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6">
                <MudNumericField @bind-Value="Poi.Radius"
                                 Label="Bán kính (m)" Variant="Variant.Outlined"
                                 Min="10" Max="200" />
            </MudItem>
            <MudItem xs="6">
                <MudNumericField @bind-Value="Poi.Latitude"
                                 Label="Latitude" Variant="Variant.Outlined"
                                 Format="F6" />
            </MudItem>
            <MudItem xs="6">
                <MudNumericField @bind-Value="Poi.Longitude"
                                 Label="Longitude" Variant="Variant.Outlined"
                                 Format="F6" />
            </MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.subtitle1" Class="mt-2 mb-1">
                    📝 Nội dung thuyết minh
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                    Nhập tiếng Việt → bấm dịch tự động → Gemini điền các ngôn ngữ khác
                </MudText>
            </MudItem>

            <MudItem xs="12">
                <MudTextField Value="@GetContent("vi")"
                              ValueChanged="@((string v) => SetContent("vi", v))"
                              Label="🇻🇳 Tiếng Việt (bắt buộc)"
                              Variant="Variant.Outlined"
                              Lines="4" />
            </MudItem>

            <MudItem xs="12">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.AutoAwesome"
                           OnClick="TranslateAll"
                           Disabled="_translating"
                           FullWidth="true">
                    @if (_translating)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Gemini đang dịch...</span>
                    }
                    else
                    {
                        <span>✨ Dịch tự động sang EN / ZH / JA / KO</span>
                    }
                </MudButton>
            </MudItem>

            @foreach (var lang in _otherLangs)
            {
                <MudItem xs="12">
                    <MudTextField Value="@GetContent(lang.Key)"
                                  ValueChanged="@((string v) => SetContent(lang.Key, v))"
                                  Label="@lang.Value"
                                  Variant="Variant.Outlined"
                                  Lines="3" />
                </MudItem>
            }

            <MudItem xs="6">
                <MudSwitch @bind-Value="Poi.IsActive"
                           Color="Color.Success"
                           T="bool"
                           Label="Kích hoạt" />
            </MudItem>

            @if (Poi.RequirePayment)
            {
                <MudItem xs="12">
                    <MudNumericField @bind-Value="Poi.Price"
                                     Label="Giá tiền (VNĐ)" Variant="Variant.Outlined"
                                     Step="5000" Min="0" 
                                     AdornmentText="VNĐ" Adornment="Adornment.End" />
                </MudItem>
            }
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit">Lưu</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance? MudDialog { get; set; }
    [Parameter] public PoiModel Poi { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; } = false;

    bool _translating = false;

    readonly Dictionary<string, string> _otherLangs = new()
    {
        { "en", "🇬🇧 English" },
        { "zh", "🇨🇳 中文" },
        { "ja", "🇯🇵 日本語" },
        { "ko", "🇰🇷 한국어" },
    };

    string GetContent(string lang)
        => Poi.Content.TryGetValue(lang, out var v) ? v : "";

    void SetContent(string lang, string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            Poi.Content.Remove(lang);
        else
            Poi.Content[lang] = value;
    }

    async Task TranslateAll()
    {
        var viText = GetContent("vi");
        if (string.IsNullOrWhiteSpace(viText))
        {
            Snackbar.Add("⚠️ Vui lòng nhập nội dung tiếng Việt trước!", Severity.Warning);
            return;
        }

        _translating = true;

        try
        {
            var response = await Http.PostAsJsonAsync(
                "api/translate",
                new { text = viText }
            );

            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add("❌ Lỗi dịch: " + response.StatusCode, Severity.Error);
                return;
            }

            var root = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
            int count = 0;

            foreach (var lang in new[] { "en", "zh", "ja", "ko" })
            {
                if (root.TryGetProperty(lang, out var val))
                {
                    var text = val.GetString() ?? "";
                    if (!string.IsNullOrWhiteSpace(text))
                    {
                        SetContent(lang, text);
                        count++;
                    }
                }
            }

            Snackbar.Add(count > 0
                ? "✅ Đã dịch sang " + count + " ngôn ngữ!"
                : "❌ Không parse được kết quả",
                count > 0 ? Severity.Success : Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add("❌ Lỗi: " + ex.Message, Severity.Error);
        }
        finally
        {
            _translating = false;
        }
    }

    void Submit() => MudDialog?.Close(DialogResult.Ok(Poi));
    void Cancel() => MudDialog?.Cancel();
}
